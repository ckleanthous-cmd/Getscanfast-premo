import { useEffect, useMemo, useState } from "react";

function HubSpotForm() {
  const portalId = import.meta.env.VITE_HUBSPOT_PORTAL_ID;
  const formId = import.meta.env.VITE_HUBSPOT_FORM_ID;
  const region = import.meta.env.VITE_HUBSPOT_REGION || "eu1";
  const [loaded, setLoaded] = useState(false);

  useEffect(() => {
    if (!portalId || !formId) return;

    const existing = document.querySelector('script[data-hubspot-form="true"]');

    const createForm = () => {
      if (window.hbspt) {
        const target = document.getElementById("hubspot-form");
        if (target) target.innerHTML = "";
        window.hbspt.forms.create({
          region,
          portalId,
          formId,
          target: "#hubspot-form",
        });
        setLoaded(true);
      }
    };

    if (existing) {
      createForm();
      return;
    }

    const script = document.createElement("script");
    script.src = "https://js.hsforms.net/forms/embed/v2.js";
    script.async = true;
    script.dataset.hubspotForm = "true";
    script.onload = createForm;
    document.body.appendChild(script);
  }, [portalId, formId, region]);

  if (!portalId || !formId) {
    return (
      <div className="space-y-4">
        <div>
          <label className="mb-2 block text-sm font-medium text-slate-700">What scan do you need?</label>
          <select className="w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm">
            <option>MRI</option>
            <option>CT</option>
            <option>Not sure</option>
          </select>
        </div>
        <div className="grid gap-4 sm:grid-cols-2">
          <input className="w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm" placeholder="Area or postcode" />
          <input className="w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm" placeholder="Phone number" />
        </div>
        <input className="w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm" placeholder="Email address" />
        <textarea className="w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm" rows="4" placeholder="Anything helpful to know?" />
        <button type="button" className="w-full rounded-2xl bg-slate-900 px-6 py-3 text-sm font-medium text-white">
          Connect HubSpot to enable live form
        </button>
        <p className="text-xs leading-5 text-slate-500">
          Add your HubSpot environment variables in Vercel or a local .env file to replace this placeholder with your live form.
        </p>
      </div>
    );
  }

  return (
    <>
      <div id="hubspot-form" />
      {!loaded && (
        <p className="mt-4 text-xs text-slate-500">Loading form…</p>
      )}
    </>
  );
}

function FeatureCard({ title, text }) {
  return (
    <div className="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h3 className="text-xl font-semibold">{title}</h3>
      <p className="mt-3 text-sm leading-6 text-slate-600">{text}</p>
    </div>
  );
}

